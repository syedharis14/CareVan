# Copy to .env and adjust. Values below match the root docker-compose Postgres.
DATABASE_URL="postgresql://carevan:carevan_dev@localhost:5433/carevan?schema=public"
# Min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET="replace-with-openssl-rand-hex-32-output-min-32-chars"
PORT=3005
# Comma-separated CORS allowlist; leave unset in local dev to allow any origin.
# CORS_ORIGINS="http://localhost:3000"
