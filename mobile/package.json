{
  "name": "@carevan/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "eas-build-post-install": "pnpm --filter @carevan/shared build",
    "build:dev:android": "eas build --profile development --platform android",
    "build:dev:ios": "eas build --profile development --platform ios",
    "build:preview:android": "eas build --profile preview --platform android"
  },
  "dependencies": {
    "@carevan/shared": "workspace:*",
    "@expo-google-fonts/inter": "^0.4.2",
    "@react-navigation/bottom-tabs": "^7.18.5",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.0",
    "expo-crypto": "~15.0.0",
    "expo-dev-client": "~6.0.0",
    "expo-device": "~8.0.0",
    "expo-linking": "~8.0.0",
    "expo-location": "~19.0.0",
    "expo-notifications": "~0.32.0",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "^31.0.13",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-task-manager": "~14.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "expo": {
    "autolinking": {
      "searchPaths": [
        "../node_modules"
      ]
    }
  }
}
